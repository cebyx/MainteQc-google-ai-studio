{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the system (admin, technician, or client)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "TECHNICIAN", "CLIENT"] },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "specialties": { "type": "array", "items": { "type": "string" } },
        "company": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "busy", "offline", "active", "inactive"] },
        "companyName": { "type": "string" },
        "billingAddress": { "type": "string" },
        "notes": { "type": "string" },
        "preferredContactMethod": { "type": "string", "enum": ["email", "phone", "text"] }
      },
      "required": ["uid", "role", "fullName", "email"]
    },
    "Ticket": {
      "title": "Ticket",
      "description": "A service request or job",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending_review", "approved", "proposed", "scheduled", "on_the_way", "arrived", "in_progress", "waiting_on_parts", "completed", "cancelled", "rejected", "unable_to_complete", "missed", "reschedule_requested"] },
        "urgency": { "type": "string", "enum": ["low", "medium", "high", "emergency"] },
        "category": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "propertyId": { "type": "string" },
        "propertyNickname": { "type": "string" },
        "serviceAddress": { "type": "string" },
        "scheduledDate": { "type": "string" },
        "scheduledTime": { "type": "string" },
        "assignedTechnicianId": { "type": "string" },
        "assignedTechnicianName": { "type": "string" },
        "adminNotes": { "type": "string" },
        "technicianNotes": { "type": "string" },
        "completionNotes": { "type": "string" },
        "createdByEmail": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "description", "status", "urgency", "category", "clientId", "clientName", "propertyId", "propertyNickname", "serviceAddress", "createdByEmail", "createdAt"]
    },
    "Property": {
      "title": "Property",
      "description": "A client's property",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "nickname": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zip": { "type": "string" },
        "propertyType": { "type": "string", "enum": ["residential", "commercial"] }
      },
      "required": ["clientId", "nickname", "address", "city", "state", "zip", "propertyType"]
    },
    "Message": {
      "title": "Message",
      "description": "A message related to a ticket",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderRole": { "type": "string" },
        "recipientId": { "type": "string" },
        "recipientRole": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" },
        "read": { "type": "boolean" }
      },
      "required": ["ticketId", "senderId", "senderRole", "recipientId", "recipientRole", "text", "timestamp", "read"]
    },
    "BrandSettings": {
      "title": "Brand Settings",
      "description": "White-label branding settings",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "tagline": { "type": "string" },
        "logo": { "type": "string" },
        "accentColor": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "businessHours": { "type": "string" },
        "serviceCategories": { "type": "array", "items": { "type": "string" } },
        "address": { "type": "string" }
      },
      "required": ["companyName", "tagline", "logo", "accentColor", "email", "phone", "businessHours", "serviceCategories", "address"]
    },
    "Quote": {
      "title": "Quote",
      "description": "A quote or estimate for a ticket",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string" },
        "clientId": { "type": "string" },
        "propertyId": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "sent", "accepted", "declined"] },
        "subtotal": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "lineItems": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "rate": { "type": "number" },
              "total": { "type": "number" }
            },
            "required": ["description", "quantity", "rate", "total"]
          } 
        },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" },
        "sentDate": { "type": "string" },
        "acceptedDate": { "type": "string" },
        "declinedDate": { "type": "string" },
        "approvalId": { "type": "string" },
        "authorizationId": { "type": "string" }
      },
      "required": ["ticketId", "clientId", "propertyId", "status", "subtotal", "tax", "total", "lineItems", "notes", "createdAt"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "An invoice for a ticket",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string" },
        "clientId": { "type": "string" },
        "propertyId": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "unpaid", "paid", "overdue"] },
        "subtotal": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "lineItems": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "rate": { "type": "number" },
              "total": { "type": "number" }
            },
            "required": ["description", "quantity", "rate", "total"]
          } 
        },
        "notes": { "type": "string" },
        "dueDate": { "type": "string" },
        "createdAt": { "type": "string" },
        "paidDate": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "paymentIds": { "type": "array", "items": { "type": "string" } },
        "authorizationId": { "type": "string" }
      },
      "required": ["ticketId", "clientId", "propertyId", "status", "subtotal", "tax", "total", "lineItems", "notes", "dueDate", "createdAt"]
    },
    "ActivityEvent": {
      "title": "Activity Event",
      "description": "An event in the timeline of a ticket",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string" },
        "clientId": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "actorId": { "type": "string" },
        "actorName": { "type": "string" },
        "actorRole": { "type": "string" },
        "timestamp": { "type": "string" },
        "metadata": { "type": "object" }
      },
      "required": ["ticketId", "clientId", "type", "description", "actorId", "actorName", "actorRole", "timestamp"]
    },
    "Attachment": {
      "title": "Attachment",
      "description": "A file or photo attached to a ticket",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string" },
        "uploadedById": { "type": "string" },
        "uploadedByRole": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "url": { "type": "string" },
        "storagePath": { "type": "string" },
        "category": { "type": "string" },
        "timestamp": { "type": "string" },
        "visibility": { "type": "string", "enum": ["internal", "client"] }
      },
      "required": ["ticketId", "uploadedById", "uploadedByRole", "fileName", "fileType", "url", "storagePath", "category", "timestamp", "visibility"]
    },
    "MaterialUsed": {
      "title": "Material Used",
      "description": "A part or material used on a ticket",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string" },
        "description": { "type": "string" },
        "quantity": { "type": "number" },
        "unitCost": { "type": "number" },
        "total": { "type": "number" },
        "notes": { "type": "string" },
        "addedById": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["ticketId", "description", "quantity", "addedById", "timestamp"]
    },
    "ServiceSummary": {
      "title": "Service Summary",
      "description": "A structured completion record for a ticket",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string" },
        "completedById": { "type": "string" },
        "completedByName": { "type": "string" },
        "completionTimestamp": { "type": "string" },
        "summary": { "type": "string" },
        "workPerformed": { "type": "string" },
        "followUpNeeded": { "type": "boolean" },
        "recommendedNextSteps": { "type": "string" },
        "clientVisibleNotes": { "type": "string" },
        "internalNotes": { "type": "string" }
      },
      "required": ["ticketId", "completedById", "completedByName", "completionTimestamp", "summary", "workPerformed", "followUpNeeded", "recommendedNextSteps", "clientVisibleNotes"]
    },
    "ClientAccount": {
      "title": "Client Account",
      "description": "A client organization or account",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] }
      },
      "required": ["name", "ownerId", "createdAt", "status"]
    },
    "ClientMember": {
      "title": "Client Member",
      "description": "A user within a client account",
      "type": "object",
      "properties": {
        "accountId": { "type": "string" },
        "clientId": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "admin", "member", "viewer"] },
        "addedAt": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "invited", "deactivated"] }
      },
      "required": ["accountId", "clientId", "role", "addedAt", "status"]
    },
    "MaintenancePlan": {
      "title": "Maintenance Plan",
      "description": "A recurring service plan",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "frequency": { "type": "string", "enum": ["monthly", "quarterly", "semi-annual", "annual", "custom"] },
        "status": { "type": "string", "enum": ["active", "paused", "cancelled"] },
        "nextDueDate": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["clientId", "propertyId", "title", "description", "category", "frequency", "status", "nextDueDate", "createdAt"]
    },
    "PaymentRecord": {
      "title": "Payment Record",
      "description": "A record of a payment made for an invoice",
      "type": "object",
      "properties": {
        "invoiceId": { "type": "string" },
        "ticketId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientAccountId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed", "refunded"] },
        "method": { "type": "string" },
        "timestamp": { "type": "string" },
        "recordedBy": { "type": "string" },
        "recordedByName": { "type": "string" },
        "recordedByRole": { "type": "string" }
      },
      "required": ["invoiceId", "clientId", "amount", "status", "method", "timestamp", "recordedBy"]
    },
    "ApprovalRecord": {
      "title": "Approval Record",
      "description": "A record of a quote approval",
      "type": "object",
      "properties": {
        "quoteId": { "type": "string" },
        "ticketId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientAccountId": { "type": "string" },
        "approvedByUserId": { "type": "string" },
        "approvedByName": { "type": "string" },
        "status": { "type": "string", "enum": ["approved", "declined"] },
        "timestamp": { "type": "string" },
        "signatureName": { "type": "string" },
        "authorizationType": { "type": "string" }
      },
      "required": ["quoteId", "ticketId", "clientId", "status", "timestamp", "signatureName"]
    },
    "AuthorizationRecord": {
      "title": "Authorization Record",
      "description": "A record of a work authorization",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientAccountId": { "type": "string" },
        "type": { "type": "string", "enum": ["work_start", "completion_signoff", "quote_approval"] },
        "timestamp": { "type": "string" },
        "signatureName": { "type": "string" },
        "approvedByUserId": { "type": "string" },
        "approvedByName": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["authorized", "revoked"] }
      },
      "required": ["ticketId", "clientId", "type", "timestamp", "signatureName", "approvedByUserId", "approvedByName"]
    },
    "ClientInvitation": {
      "title": "Client Invitation",
      "description": "An invitation to join a client account",
      "type": "object",
      "properties": {
        "accountId": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "admin", "member", "viewer"] },
        "invitedBy": { "type": "string" },
        "invitedAt": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "expired", "revoked"] },
        "token": { "type": "string" }
      },
      "required": ["accountId", "email", "role", "invitedBy", "invitedAt", "status", "token"]
    },
    "ReminderEvent": {
      "title": "Reminder Event",
      "description": "A record of a reminder sent for a quote or invoice",
      "type": "object",
      "properties": {
        "targetId": { "type": "string" },
        "targetType": { "type": "string", "enum": ["quote", "invoice"] },
        "clientId": { "type": "string" },
        "sentAt": { "type": "string" },
        "sentBy": { "type": "string" },
        "type": { "type": "string", "enum": ["initial", "follow_up", "overdue", "collections"] },
        "notes": { "type": "string" }
      },
      "required": ["targetId", "targetType", "clientId", "sentAt", "sentBy", "type"]
    },
    "TechnicianAvailabilityRule": {
      "title": "Technician Availability Rule",
      "description": "Recurring availability for a technician",
      "type": "object",
      "properties": {
        "technicianId": { "type": "string" },
        "dayOfWeek": { "type": "integer" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "enabled": { "type": "boolean" }
      },
      "required": ["technicianId", "dayOfWeek", "startTime", "endTime", "enabled"]
    },
    "BlockedSlot": {
      "title": "Blocked Slot",
      "description": "A period when a technician is unavailable",
      "type": "object",
      "properties": {
        "technicianId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "type": { "type": "string", "enum": ["pto", "lunch", "break", "personal", "other"] }
      },
      "required": ["technicianId", "title", "startTime", "endTime", "type"]
    },
    "AppointmentRecord": {
      "title": "Appointment Record",
      "description": "A scheduled appointment for a ticket",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string" },
        "technicianId": { "type": "string" },
        "clientId": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "status": { "type": "string", "enum": ["proposed", "confirmed", "reschedule_requested", "missed", "completed", "cancelled"] },
        "proposedBy": { "type": "string", "enum": ["ADMIN", "TECHNICIAN", "CLIENT"] },
        "confirmedAt": { "type": "string" },
        "rescheduleReason": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["ticketId", "technicianId", "clientId", "startTime", "endTime", "status", "proposedBy", "createdAt", "updatedAt"]
    },
    "Vendor": {
      "title": "Vendor",
      "description": "A supplier or service provider",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contactName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "status", "createdAt"]
    },
    "VendorBill": {
      "title": "Vendor Bill",
      "description": "A bill from a vendor",
      "type": "object",
      "properties": {
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "billNumber": { "type": "string" },
        "ticketId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "paid", "overdue", "cancelled"] },
        "total": { "type": "number" },
        "dueDate": { "type": "string" },
        "billDate": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["vendorId", "vendorName", "status", "total", "dueDate", "billDate", "createdAt"]
    },
    "VendorPayment": {
      "title": "Vendor Payment",
      "description": "A payment made to a vendor",
      "type": "object",
      "properties": {
        "vendorId": { "type": "string" },
        "billId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "reference": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["vendorId", "billId", "amount", "method", "timestamp"]
    },
    "ExpenseRecord": {
      "title": "Expense Record",
      "description": "A general business expense",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "ticketId": { "type": "string" },
        "technicianId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "reimbursed", "rejected"] },
        "receiptUrl": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["category", "amount", "description", "date", "status", "createdAt"]
    },
    "TechnicianPayProfile": {
      "title": "Technician Pay Profile",
      "description": "Payroll settings for a technician",
      "type": "object",
      "properties": {
        "technicianId": { "type": "string" },
        "hourlyRate": { "type": "number" },
        "travelRate": { "type": "number" },
        "overtimeRate": { "type": "number" },
        "payFrequency": { "type": "string", "enum": ["weekly", "bi-weekly", "monthly"] },
        "taxStatus": { "type": "string" }
      },
      "required": ["technicianId", "hourlyRate"]
    },
    "TimesheetApproval": {
      "title": "Timesheet Approval",
      "description": "Approval record for a technician's work sessions",
      "type": "object",
      "properties": {
        "technicianId": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "totalHours": { "type": "number" },
        "totalPay": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "paid"] },
        "approvedBy": { "type": "string" },
        "approvedAt": { "type": "string" }
      },
      "required": ["technicianId", "startDate", "endDate", "totalHours", "totalPay", "status"]
    },
    "PayrollExportBatch": {
      "title": "Payroll Export Batch",
      "description": "A batch of payroll records for export",
      "type": "object",
      "properties": {
        "batchName": { "type": "string" },
        "periodStart": { "type": "string" },
        "periodEnd": { "type": "string" },
        "totalAmount": { "type": "number" },
        "employeeCount": { "type": "integer" },
        "status": { "type": "string", "enum": ["draft", "exported", "processed"] },
        "createdAt": { "type": "string" }
      },
      "required": ["batchName", "periodStart", "periodEnd", "totalAmount", "employeeCount", "status", "createdAt"]
    },
    "TaxProfile": {
      "title": "Tax Profile",
      "description": "Tax settings for the business",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "rate": { "type": "number" },
        "description": { "type": "string" },
        "isDefault": { "type": "boolean" }
      },
      "required": ["name", "rate"]
    },
    "FinancialActivity": {
      "title": "Financial Activity",
      "description": "A ledger entry for financial transactions",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense", "payroll", "tax", "vendor_payment"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "timestamp": { "type": "string" },
        "relatedId": { "type": "string" },
        "relatedType": { "type": "string" },
        "actorId": { "type": "string" },
        "actorName": { "type": "string" }
      },
      "required": ["type", "amount", "description", "timestamp", "actorId", "actorName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/tickets/{ticketId}": {
      "schema": { "$ref": "#/entities/Ticket" },
      "description": "Stores service tickets"
    },
    "/properties/{propertyId}": {
      "schema": { "$ref": "#/entities/Property" },
      "description": "Stores client properties"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores messages"
    },
    "/brandSettings/main": {
      "schema": { "$ref": "#/entities/BrandSettings" },
      "description": "Stores brand settings"
    },
    "/quotes/{quoteId}": {
      "schema": { "$ref": "#/entities/Quote" },
      "description": "Stores quotes"
    },
    "/invoices/{invoiceId}": {
      "schema": { "$ref": "#/entities/Invoice" },
      "description": "Stores invoices"
    },
    "/activities/{activityId}": {
      "schema": { "$ref": "#/entities/ActivityEvent" },
      "description": "Stores activity events"
    },
    "/attachments/{attachmentId}": {
      "schema": { "$ref": "#/entities/Attachment" },
      "description": "Stores ticket attachments"
    },
    "/materialsUsed/{materialId}": {
      "schema": { "$ref": "#/entities/MaterialUsed" },
      "description": "Stores materials used on tickets"
    },
    "/serviceSummaries/{summaryId}": {
